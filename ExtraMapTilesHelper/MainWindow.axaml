<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:ExtraMapTilesHelper.Models"
        x:Class="ExtraMapTilesHelper.MainWindow"
        Title="Extra Map Tiles Helper"
        Background="#1e1e2e" Foreground="#cdd6f4"
        Width="1600" Height="800"
        Loaded="OnMainWindowLoaded"
        Icon="Assets/icon.ico">

    <Grid ColumnDefinitions="300, *, 250">
        
        <Border Grid.Column="0" Background="#181825" BorderBrush="#313244" BorderThickness="0,0,1,0">
            <DockPanel Margin="10">
                <Button x:Name="ImportButton" DockPanel.Dock="Top" Content="Import YTDs" Click="OnImportClicked" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Background="#89b4fa" Foreground="#11111b" FontWeight="Bold" Margin="0,0,0,10"/>
                
                <TreeView x:Name="TextureTree" Background="Transparent" BorderThickness="0">
                    
                    <TreeView.Styles>
                        <Style Selector="TreeViewItem" x:DataType="models:DictionaryItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        </Style>
                    </TreeView.Styles>
                    
                    <TreeView.DataTemplates>
                        <TreeDataTemplate DataType="models:DictionaryItem" ItemsSource="{Binding Textures}">
                            <Border Background="Transparent" PointerPressed="OnDictionaryPointerPressed">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#89b4fa" Padding="0,5"/>
                            </Border>
                        </TreeDataTemplate>
                        
                        <DataTemplate DataType="models:TextureItem">
                            <Border Background="Transparent" PointerPressed="OnItemPointerPressed">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Image Source="{Binding Preview}" Width="48" Height="48" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                        
                    </TreeView.DataTemplates>
                </TreeView>
            </DockPanel>
        </Border>

        <ScrollViewer x:Name="MapScrollViewer" Grid.Column="1" 
                      HorizontalScrollBarVisibility="Visible" VerticalScrollBarVisibility="Visible"
                      AllowAutoHide="False"> <LayoutTransformControl x:Name="MapZoomTransform">
                <Canvas x:Name="MapCanvas" Width="8192" Height="8192" DragDrop.AllowDrop="True" PointerWheelChanged="OnMapPointerWheelChanged">
                    <Canvas.Background>
                        <VisualBrush TileMode="Tile" SourceRect="0,0,256,256" DestinationRect="0,0,256,256">
                            <VisualBrush.Visual>
                                <Rectangle Width="256" Height="256" Stroke="#313244" StrokeThickness="1" Fill="#11111b"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Canvas.Background>

                    <Ellipse Canvas.Left="4086" Canvas.Top="4086" Width="20" Height="20" 
                             Fill="#f38ba8" Stroke="#11111b" StrokeThickness="2" ZIndex="100"
                             ToolTip.Tip="Center Anchor Point (4096, 4096)"/>
                </Canvas>
            </LayoutTransformControl>

        </ScrollViewer>
    </Grid>
</Window>