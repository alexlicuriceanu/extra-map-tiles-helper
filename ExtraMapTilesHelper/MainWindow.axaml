<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:ExtraMapTilesHelper.Models"
        x:Class="ExtraMapTilesHelper.MainWindow"
        Title="Extra Map Tiles Helper"
        Background="#1e1e1e"
        Foreground="#cccccc"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="12"
        MinWidth="512" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Loaded="OnMainWindowLoaded"
        KeyDown="OnWindowKeyDown"
        Icon="Assets/icon.ico">

	<LayoutTransformControl x:Name="RootTransform">
	<DockPanel>
		<Menu DockPanel.Dock="Top" Background="#2d2d30" Foreground="#cccccc">
			<MenuItem Header="_File">
				<MenuItem x:Name="ImportMenuItem" Header="_Import YTDs" Click="OnImportClicked"/>
			    
                <Separator/>
            </MenuItem>

			<MenuItem Header="_View">
				<MenuItem Click="OnResetViewClicked" HotKey="Ctrl+R">
					<MenuItem.Header>
						<Grid ColumnDefinitions="*,Auto" MinWidth="180">
							<TextBlock Grid.Column="0" Text="Reset View"/>
							<TextBlock Grid.Column="1" Text="Ctrl+R" HorizontalAlignment="Right" Opacity="0.8"/>
						</Grid>
					</MenuItem.Header>
				</MenuItem>

				<Separator/>

				<MenuItem Click="OnZoomInClicked" HotKey="Ctrl+OemPlus">
					<MenuItem.Header>
						<Grid ColumnDefinitions="*,Auto" MinWidth="180">
							<TextBlock Grid.Column="0" Text="Zoom In"/>
							<TextBlock Grid.Column="1" Text="Ctrl++" HorizontalAlignment="Right" Opacity="0.8"/>
						</Grid>
					</MenuItem.Header>
				</MenuItem>

				<MenuItem Click="OnZoomOutClicked" HotKey="Ctrl+OemMinus">
					<MenuItem.Header>
						<Grid ColumnDefinitions="*,Auto" MinWidth="180">
							<TextBlock Grid.Column="0" Text="Zoom Out"/>
							<TextBlock Grid.Column="1" Text="Ctrl+-" HorizontalAlignment="Right" Opacity="0.8"/>
						</Grid>
					</MenuItem.Header>
				</MenuItem>
			</MenuItem>
            
			<MenuItem Header="_Options">
				<MenuItem Header="Show Default Map" ToggleType="CheckBox" IsChecked="True" Click="OnToggleDefaultTilesClicked"/>
				<MenuItem Header="Tile Snapping" ToggleType="CheckBox" IsChecked="True" Click="OnToggleTileSnappingClicked"/>
			</MenuItem>
		</Menu>

		<Grid ColumnDefinitions="300, *, 250">

			<Border Grid.Column="0" Background="#252526" BorderBrush="#3e3e42" BorderThickness="0,0,1,0">
				<TreeView x:Name="TextureTree" Background="Transparent" BorderThickness="0" Margin="10">
                    
                    <TreeView.Styles>
                        <Style Selector="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}" />
                        </Style>
                    </TreeView.Styles>
                    
                    <TreeView.DataTemplates>
                        <TreeDataTemplate DataType="models:DictionaryItem" ItemsSource="{Binding Textures}">
                            <Border Background="Transparent" PointerPressed="OnDictionaryPointerPressed">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#4fc1ff" Padding="0,5"/>
                            </Border>
                        </TreeDataTemplate>
                        
                        <DataTemplate DataType="models:TextureItem">
                            <Border Background="Transparent" PointerPressed="OnItemPointerPressed">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Image Source="{Binding Preview}" Width="48" Height="48" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                        
                    </TreeView.DataTemplates>
                </TreeView>
            </Border>

            <ScrollViewer x:Name="MapScrollViewer" Grid.Column="1"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      AllowAutoHide="False"
                      PointerPressed="OnMapPointerPressed"
                      PointerMoved="OnMapPointerMoved"
                      PointerReleased="OnMapPointerReleased">
            
            <LayoutTransformControl x:Name="MapZoomTransform"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                <Canvas x:Name="MapCanvas"
                        Width="100000"
                        Height="100000"
                        DragDrop.AllowDrop="True"
                        PointerWheelChanged="OnMapPointerWheelChanged"
                        RenderOptions.BitmapInterpolationMode="LowQuality">
                    
                    <Canvas.Background>
                        <VisualBrush TileMode="Tile" SourceRect="0,0,256,256" DestinationRect="0,0,256,256">
                            <VisualBrush.Visual>
                                <Rectangle Width="256" Height="256" Stroke="#3e3e42" StrokeThickness="1" Fill="#121212" IsHitTestVisible="False"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Canvas.Background>

                    <Rectangle x:Name="DragHighlight"
                               Width="256" Height="256"
                               Fill="#66007acc" Stroke="#007acc" StrokeThickness="2"
                               IsHitTestVisible="False" IsVisible="False" ZIndex="90" />

                    <Rectangle x:Name="SelectionHighlight"
                               Width="256" Height="256"
                               Stroke="#e3a826" StrokeThickness="3"
                               IsHitTestVisible="False" IsVisible="False" ZIndex="95" />

                    <Ellipse Canvas.Left="49910"
                             Canvas.Top="49910"
                             Width="20"
                             Height="20" 
                             Fill="#ff0000"
                             Stroke="#1e1e1e"
                             StrokeThickness="2"
                             ZIndex="100"
                             ToolTip.Tip="In-game logical center point: top left corner of tile at offsets (0, 0)"/>
                </Canvas>
            </LayoutTransformControl>

            </ScrollViewer>

            <Border Grid.Column="2" Background="#252526" BorderBrush="#3e3e42" BorderThickness="1,0,0,0">
                <Grid RowDefinitions="*,*">
                    
                    <!-- Upper half: Selected Tile Properties -->
                    <Border Grid.Row="0" BorderBrush="#3e3e42" BorderThickness="0,0,0,1" Background="#1e1e1e">
                        <DockPanel x:Name="TileEditorPanel" IsVisible="False" Margin="10">
                            <TextBlock DockPanel.Dock="Top" Text="Tile Properties" FontWeight="Bold" Foreground="#cccccc" Margin="0,0,0,10"/>
                            
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                                <Image x:Name="SelectedTilePreview" Width="64" Height="64" Stretch="Uniform"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="SelectedTileName" FontWeight="Bold" Foreground="#4fc1ff"/>
                                    <TextBlock x:Name="SelectedTileYtd" FontSize="11" Opacity="0.8"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="Auto, *" DockPanel.Dock="Top">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                <NumericUpDown x:Name="EditXBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Increment="1.0" ValueChanged="OnEditBoxValueChanged"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Y:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <NumericUpDown x:Name="EditYBox" Grid.Row="1" Grid.Column="1" Increment="1.0" ValueChanged="OnEditBoxValueChanged"/>
                            </Grid>
                        </DockPanel>
                    </Border>

                    <!-- Lower half for Placed Tiles Queue -->
                    <DockPanel Grid.Row="1">
                        <TextBlock DockPanel.Dock="Top" Text="Placed Tiles Queue" FontWeight="Bold" Background="#2d2d30" Foreground="#cccccc" Padding="10"/>
                        
                        <!-- ListBox inherently is scrollable when bounded inside a container -->
                        <ListBox x:Name="PlacedTilesList" Background="Transparent" Foreground="#cccccc" BorderThickness="0" Margin="0,5,0,0" SelectionChanged="OnPlacedTilesListSelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="models:PlacedTile">
                                    <StackPanel Margin="0,0,0,5">
                                        <TextBlock Text="{Binding TxdName}" FontWeight="Bold" Foreground="#4fc1ff"/>
                                        <TextBlock Text="{Binding YtdName, StringFormat='YTD: {0}'}" FontSize="11" Opacity="0.8"/>
                                        <TextBlock FontSize="11" Opacity="0.8">
                                            <Run Text="Pos: ("/>
                                            <Run Text="{Binding X}"/>
                                            <Run Text=", "/>
                                            <Run Text="{Binding Y}"/>
                                            <Run Text=")"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Grid>
            </Border>

        </Grid>
	</DockPanel>
	</LayoutTransformControl>
</Window>