<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:ExtraMapTilesHelper.Models"
        x:Class="ExtraMapTilesHelper.MainWindow"
        Title="Extra Map Tiles Helper"
        Background="#1e1e1e"
        Foreground="White"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="12"
        MinWidth="512" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Loaded="OnMainWindowLoaded"
        Icon="Assets/icon.ico">

	<LayoutTransformControl x:Name="RootTransform">
	<DockPanel>
		<DockPanel DockPanel.Dock="Top" Background="#2d2d30">
			<!-- NEW: Status Indicator in the top right -->
			<StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
				<TextBlock x:Name="StatusText" Text="Ready" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0" />
			</StackPanel>

			<!-- Modified: Set the menu's background to transparent since DockPanel now holds the color -->
			<Menu Background="Transparent" Foreground="White">
				<MenuItem Header="_File">
					<MenuItem x:Name="ImportMenuItem" Header="_Import YTDs" Click="OnImportClicked"/>
					<Separator/>
					<MenuItem Header="E_xit" Click="OnExitClicked"/>
				</MenuItem>

				<MenuItem Header="_View">
					<MenuItem Click="OnResetViewClicked">
						<MenuItem.Header>
							<TextBlock Text="Reset View"/>
						</MenuItem.Header>
					</MenuItem>
				</MenuItem>
				
				<MenuItem Header="_Options">
					<MenuItem Header="Show Default Map" ToggleType="CheckBox" IsChecked="True" Click="OnToggleDefaultTilesClicked"/>
					<MenuItem Header="Tile Snapping" ToggleType="CheckBox" IsChecked="True" Click="OnToggleTileSnappingClicked"/>
				</MenuItem>
			</Menu>
		</DockPanel>

		<Grid ColumnDefinitions="300, *, 250">

			<Border Grid.Column="0"
        Background="#1e1e1e"
        BorderBrush="#3e3e42"
        BorderThickness="0,1,1,0">
				<DockPanel>
					<TextBlock x:Name="DictionaryCountText" 
                               DockPanel.Dock="Top"
                               Text="Texture Dictionaries (0)"
                               FontWeight="Normal"
                               Background="#2d2d30"
                               Foreground="White"
                               Padding="10"/>

					<TreeView x:Name="TextureTree" Background="Transparent" BorderThickness="0" Margin="10,5,10,10">
						<TreeView.Styles>
							<Style Selector="TreeViewItem">
								<Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}" />
							</Style>
						</TreeView.Styles>

						<TreeView.DataTemplates>
							<TreeDataTemplate DataType="models:DictionaryItem" ItemsSource="{Binding Textures}">
								<Border Background="Transparent" PointerPressed="OnDictionaryPointerPressed">
									<Border.ContextMenu>
										<ContextMenu FontSize="12" FontFamily="Segoe UI Variable, Segoe UI">
											<MenuItem Header="Remove from project"
													  Tag="{Binding}"
													  Click="OnRemoveDictionaryClicked" />
										</ContextMenu>
									</Border.ContextMenu>
									<TextBlock Text="{Binding Name}" FontWeight="Normal" Foreground="White" Padding="0,5"/>
								</Border>
							</TreeDataTemplate>

							<DataTemplate DataType="models:TextureItem">
								<Border Background="Transparent" PointerPressed="OnItemPointerPressed">
									<StackPanel Orientation="Horizontal" Spacing="10">
										<Image Source="{Binding Preview}" Width="48" Height="48" />
										<TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
									</StackPanel>
								</Border>
							</DataTemplate>
						</TreeView.DataTemplates>
					</TreeView>
				</DockPanel>
			</Border>

			<ScrollViewer x:Name="MapScrollViewer" Grid.Column="1"
					  HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"
					  AllowAutoHide="False"
					  PointerPressed="OnMapPointerPressed"
					  PointerMoved="OnMapPointerMoved"
					  PointerReleased="OnMapPointerReleased">
            
            <LayoutTransformControl x:Name="MapZoomTransform"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                <Canvas x:Name="MapCanvas"
                        Width="100000"
                        Height="100000"
                        DragDrop.AllowDrop="True"
                        PointerWheelChanged="OnMapPointerWheelChanged"
                        RenderOptions.BitmapInterpolationMode="LowQuality">
                    
                    <Canvas.Background>
                        <SolidColorBrush Color="#121212"/>
                    </Canvas.Background>

                    <!-- The grid lines drawn ON TOP of the tiles -->
                    <Rectangle Width="100000" Height="100000" IsHitTestVisible="False" ZIndex="5">
                        <Rectangle.Fill>
                            <VisualBrush TileMode="Tile" SourceRect="0,0,256,256" DestinationRect="0,0,256,256">
                                <VisualBrush.Visual>
                                    <Rectangle Width="256" Height="256" Stroke="#3e3e42" StrokeThickness="1" Fill="Transparent" IsHitTestVisible="False"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <Border x:Name="DragHighlight"
                            Width="256" Height="256"
                            Background="Transparent" BorderBrush="#e3a826" BorderThickness="3"
                            IsHitTestVisible="False" IsVisible="False" ZIndex="98">
                        <Image x:Name="DragHighlightImage" Stretch="Fill" Opacity="0.6"/>
                    </Border>

                    <Rectangle x:Name="SelectionHighlight"
                               Width="256" Height="256"
                               Stroke="#e3a826" StrokeThickness="3"
                               IsHitTestVisible="False" IsVisible="False" ZIndex="95" />

                    <Ellipse Canvas.Left="49910"
                             Canvas.Top="49910"
                             Width="20"
                             Height="20" 
                             Fill="#e3a826"
                             Stroke="#1e1e1e"
                             StrokeThickness="2"
                             ZIndex="100"
                             ToolTip.Tip="In-game logical center point: top left corner of tile at offsets (0, 0)"/>
                </Canvas>
            </LayoutTransformControl>

            </ScrollViewer>

            <Border Grid.Column="2"
        Background="#252526"
        BorderBrush="#3e3e42"
        BorderThickness="1,1,0,0">
                <Grid RowDefinitions="*,*">
                    
                    <!-- Upper half: Selected Tile Properties -->
                    <Border Grid.Row="0" BorderBrush="#3e3e42" BorderThickness="0,0,0,1" Background="#1e1e1e">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Selected Tile"
                                       FontWeight="Normal"
                                       Background="#2d2d30"
                                       Foreground="White"
                                       Padding="10"/>

                            <ScrollViewer x:Name="TileEditorPanel"
                                          IsVisible="False"
                                          Margin="10,10,10,10"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
                                        <Image x:Name="SelectedTilePreview" Width="64" Height="64" Stretch="Uniform"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="SelectedTileName" FontWeight="Normal" Foreground="White"/>
                                            <TextBlock x:Name="SelectedTileYtd" FontSize="11" Opacity="0.8"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                        <StackPanel DockPanel.Dock="Right" Spacing="5" VerticalAlignment="Center">
                                            <Button Content="Remove"
                                                    Background="#d13438"
                                                    Foreground="White"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Center"
                                                    Click="OnRemoveTileClicked"/>
                                            <Button Content="Reset"
                                                    Background="#555555"
                                                    Foreground="White"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Center"
                                                    Click="OnResetTileClicked"/>
                                        </StackPanel>
                                        
                                        <StackPanel Spacing="5">
                                            <ToggleSwitch x:Name="CenteredToggle"
                                                          OffContent="Centered"
                                                          OnContent="Centered"
                                                          IsChecked="False"
                                                          Checked="OnCenteredToggled"
                                                          Unchecked="OnCenteredToggled"/>

                                            <ToggleSwitch x:Name="CoordinateModeToggle"
                                                          OffContent="Coordinate Mode"
                                                          OnContent="Offset Mode"
                                                          IsChecked="True"
                                                          Checked="OnCoordinateModeToggled"
                                                          Unchecked="OnCoordinateModeToggled"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto" ColumnDefinitions="Auto, *" DockPanel.Dock="Top">
                                        <TextBlock x:Name="EditXLabel" Grid.Row="0" Grid.Column="0" Text="X:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                        <NumericUpDown x:Name="EditXBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Increment="1.0" ValueChanged="OnEditBoxValueChanged"/>

                                        <TextBlock x:Name="EditYLabel" Grid.Row="1" Grid.Column="0" Text="Y:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                        <NumericUpDown x:Name="EditYBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Increment="1.0" ValueChanged="OnEditBoxValueChanged"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Alpha:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                        <NumericUpDown x:Name="EditAlphaBox" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="100" Increment="1.0" Margin="0,0,0,10" ValueChanged="OnEditAlphaBoxValueChanged"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Scale X:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                        <NumericUpDown x:Name="EditScaleXBox" Grid.Row="3" Grid.Column="1" Minimum="0.1" Maximum="10" Increment="0.1" Margin="0,0,0,10" ValueChanged="OnEditScaleBoxValueChanged"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Scale Y:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                        <NumericUpDown x:Name="EditScaleYBox" Grid.Row="4" Grid.Column="1" Minimum="0.1" Maximum="10" Increment="0.1" Margin="0,0,0,10" ValueChanged="OnEditScaleBoxValueChanged"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Rotation:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <NumericUpDown x:Name="EditRotationBox" Grid.Row="5" Grid.Column="1" Increment="1.0" ValueChanged="OnEditRotationBoxValueChanged"/>
                                    </Grid>
                                </DockPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Lower half for Placed Tiles Queue -->
                    <DockPanel Grid.Row="1" Background="#1e1e1e">
    <TextBlock DockPanel.Dock="Top" Text="Placed Tiles" FontWeight="Normal" Background="#2d2d30" Foreground="White" Padding="10"/>
    
    <!-- ListBox inherently is scrollable when bounded inside a container -->
    <ListBox x:Name="PlacedTilesList" Background="Transparent" Foreground="White" BorderThickness="0" Margin="0,5,0,0" SelectionChanged="OnPlacedTilesListSelectionChanged">
        <ListBox.ItemTemplate>
            <DataTemplate DataType="models:PlacedTileItem">
                <!-- Wrap in horizontal StackPanel for image + text -->
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,5">
                    
                    <!-- Added Thumbnail -->
                    <Image Source="{Binding Texture.Preview}" Width="32" Height="32" Stretch="Uniform" VerticalAlignment="Center" />
                    
                    <!-- Original text layout retained perfectly -->
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="11" Opacity="1.0">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}">
                                    <Binding Path="TxdName" />
                                    <Binding Path="YtdName" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock FontSize="11" Opacity="0.5">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Offsets XY: ({0:F2}, {1:F2})">
                                    <Binding Path="OffsetX" />
                                    <Binding Path="OffsetY" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock FontSize="11" Opacity="0.5">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Coords XY: ({0:F2}, {1:F2})">
                                    <Binding Path="GameX" />
                                    <Binding Path="GameY" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                    
                </StackPanel>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</DockPanel>
                </Grid>
            </Border>

        </Grid>
	</DockPanel>
	</LayoutTransformControl>
</Window>