<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ExtraMapTilesHelper.TutorialWindow"
        Title="Tutorial &amp; Steps"
        Background="#1c1c1c"
        Foreground="White"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="12"
        Width="600" Height="450"
        WindowStartupLocation="CenterOwner"
        Icon="Assets/icon.ico">
    
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="#282828" BorderBrush="#3e3e42" BorderThickness="0,0,0,1" Padding="15">
            <TextBlock Text="How to Use Extra Map Tiles Helper" FontSize="18" FontWeight="SemiBold" Foreground="White" />
        </Border>
        
        <ScrollViewer Grid.Row="1" Margin="15">
            <StackPanel Spacing="10">
                <TextBlock Text="Step 1: Importing Assets" FontWeight="Bold" FontSize="14" />
                <TextBlock Text="Start by creating and dragging your .ytd dictionary or multiple .ytd files onto the viewport or use the 'Import YTDs' menu item. Your dictionaries will appear in the panel on the left." TextWrapping="Wrap" Foreground="#cccccc" />

                <TextBlock Text="Step 2: Placing Tiles" FontWeight="Bold" FontSize="14" Margin="0,10,0,0" />
                <TextBlock Text="Drag the imported textures from the left panel onto the main map. Use the 'Tile Snapping' feature to easily align your specific map tiles together." TextWrapping="Wrap" Foreground="#cccccc" />

                <TextBlock Text="Step 3: Configuration &amp; Adjustments" FontWeight="Bold" FontSize="14" Margin="0,10,0,0" />
                <TextBlock Text="Select a tile on the map to modify its properties (position, scale, rotation, alpha, etc.) in the properties panel to the right." TextWrapping="Wrap" Foreground="#cccccc" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>